# ── SNIPPET: mpi_env_orca_ompi_overrides/DFT-singlepoint-Anvil-Slurm_default ─
# Scheduler:   any
# Tool:        orca
# Tested:      golddigr_orca_multiwfn_anvil
# Invariants:
#   - Preserve OMPI_MCA_* overrides that disable UCX and force tcp/vader to avoid transport issues.
#   - ORCA and Multiwfn paths are assumed under /opt.
# Notes: Intended to be sourced at job start (inside container or preinstalled runtime).
# ────────────────────────────────────────────────────────────

#!/bin/bash
# file: mpi_env_orca_ompi_overrides.sh

export PATH="/opt/orca:/opt/Multiwfn_bin:${PATH}"
export LD_LIBRARY_PATH="/opt/orca:${LD_LIBRARY_PATH}"

export OMPI_MCA_pml="ob1"
export OMPI_MCA_btl="self,vader,tcp"
export OMPI_MCA_mtl="^ucx"
export OMPI_MCA_osc="^ucx"
export OMPI_MCA_btl_vader_single_copy_mechanism=none
export OMPI_MCA_rmaps_base_oversubscribe=1
export OMPI_MCA_hwloc_base_binding_policy=none
export OMPI_MCA_shmem_mmap_enable_nfs_warning=0
