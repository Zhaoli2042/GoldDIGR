from typing import Dict, Any, Set

def generate_orca_input_tsopt(xyz_path: str, output_path: str, charge: int, mult: int,
                              basis_assignment: Dict[str, Set[int]], config: Dict[str, Any],
                              nprocs: int = 16, maxcore: int = 4000, job_name: str = "tsopt"):
    """Generate ORCA input for transition state optimization."""
    orca = get_orca_settings(config)

    keywords = [f"! {orca['functional']}"]
    if orca['extra_keywords']:
        keywords.append(orca['extra_keywords'])
    keywords.append(orca['aux_basis'])
    keywords.append(orca['grid'])
    if orca['dispersion']:
        keywords.append(orca['dispersion'])
    keywords.append("OptTS FREQ")

    keyword_line = " ".join(keywords)

    pal_block = f"%pal\n  nprocs {nprocs}\nend"
    maxcore_line = f"%maxcore {maxcore}"
    base_line = f'%base "{job_name}"'

    # GEOM block for TS optimization
    geom_block = """%geom
  Calc_Hess true
  NumHess true
  MaxIter 100
end"""

    coord_block = generate_coord_block(xyz_path, charge, mult, basis_assignment)
