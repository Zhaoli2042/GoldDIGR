# ── SNIPPET: config_key_validation/json_config_merge_known_keys_into_orca_defaults ─
# Scheduler:   any
# Tool:        orca
# Tested:      {{PLUGIN_NAME}}
# Notes: Prints applied overrides.
# ────────────────────────────────────────────────────────────

import os
import json
from typing import Dict, Any

ORCA_DEFAULTS = {
    "functional": "wB97X-D3BJ",
    "grid": "defgrid3",
    "basis_high": "def2-TZVP",
    "basis_low": "def2-SVP",
    "aux_basis": "def2/J",
    "dispersion": "",
    "extra_keywords": "RIJCOSX"
}

def load_config(config_path: str = None) -> Dict[str, Any]:
    """
    Load config.json if exists, merge with defaults.
    Only overrides keys that are explicitly specified.
    """
    config = {
        "orca": ORCA_DEFAULTS.copy(),
        "charge": None,  # Use from workflow_status if not specified
        "mult": None,
        "nprocs": 16,
        "maxcore": 4000
    }

    if config_path and os.path.exists(config_path):
        print(f"Loading configuration from: {config_path}")
        try:
            with open(config_path, 'r') as f:
                user_config = json.load(f)

            # Merge ORCA settings
            if "orca" in user_config:
                for key, value in user_config["orca"].items():
                    if key in config["orca"]:
                        config["orca"][key] = value
                        print(f"  Config override: orca.{key} = {value}")
                    else:
                        print(f"  Warning: Unknown ORCA setting '{key}' ignored")

            # Merge top-level settings
            for key in ["charge", "mult", "nprocs", "maxcore"]:
                if key in user_config:
                    config[key] = user_config[key]
                    print(f"  Config override: {key} = {user_config[key]}")

        except json.JSONDecodeError as e:
            print(f"  Warning: Invalid config.json format: {e}")
        except Exception as e:
            print(f"  Warning: Could not load config: {e}")

    return config


def get_orca_settings(config: Dict[str, Any]) -> Dict[str, str]:
    """Extract ORCA settings from config."""
    return config.get("orca", ORCA_DEFAULTS.copy())
